{"data": {"conn_name": "model.ecommerce_dbt.mart_customer_ltv", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "71281fc414a6b0296f0b0c8cc49573279e082a2b3fe06d524e87f381f4739ac9", "node_finished_at": "", "node_name": "mart_customer_ltv", "node_path": "marts\\mart_customer_ltv.sql", "node_relation": {"alias": "mart_customer_ltv", "database": "ecommerce_pipeline", "relation_name": "ecommerce_pipeline.dev_marts.mart_customer_ltv", "schema": "dev_marts"}, "node_started_at": "2026-06-07T19:32:07.388168", "node_status": "executing", "resource_type": "model", "unique_id": "model.ecommerce_dbt.mart_customer_ltv"}, "sql": "create or replace transient table ecommerce_pipeline.dev_marts.mart_customer_ltv\n    \n    \n    \n    as (with user_carts as (\n    select *\n    from ecommerce_pipeline.dev_intermediate.int_user_carts\n),\n\ncustomer_ltv as (\n    select\n        user_id,\n        first_name,\n        last_name,\n        age,\n        gender,\n        city,\n        state,\n        currency,\n        department,\n        job_title,\n        sum(cart_total)         as total_spent,\n        sum(discounted_total)   as total_spent_after_discount,\n        count(distinct cart_id) as number_of_orders,\n        avg(cart_total)         as average_order_value,\n        sum(total_quantity)     as total_items_purchased\n    from user_carts\n    group by\n        user_id,\n        first_name,\n        last_name,\n        age,\n        gender,\n        city,\n        state,\n        currency,\n        department,\n        job_title\n)\n\nselect * from customer_ltv\norder by total_spent desc\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.mart_customer_ltv\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "8f591da5-dc9e-4945-bd80-f56d314d7758", "level": "debug", "msg": "On model.ecommerce_dbt.mart_customer_ltv: create or replace transient table ecommerce_pipeline.dev_marts.mart_customer_ltv\n    \n    \n    \n    as (with user_carts as (\n    select *\n    from ecommerce_pipeline.dev_intermediate.int_user_carts\n),\n\ncustomer_ltv as (\n    select\n        user_id,\n        first_name,\n        last_name,\n        age,\n        gender,\n        city,\n        state,\n        currency,\n        department,\n        job_title,\n        sum(cart_total)         as total_spent,\n        sum(discounted_total)   as total_spent_after_discount,\n        count(distinct cart_id) as number_of_orders,\n        avg(cart_total)         as average_order_value,\n        sum(total_quantity)     as total_items_purchased\n    from user_carts\n    group by\n        user_id,\n        first_name,\n        last_name,\n        age,\n        gender,\n        city,\n        state,\n        currency,\n        department,\n        job_title\n)\n\nselect * from customer_ltv\norder by total_spent desc\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.mart_customer_ltv\"} */;", "name": "SQLQuery", "pid": 10232, "thread": "Thread-3", "ts": "2026-06-07T19:32:07.518686Z"}}
{"data": {"conn_name": "model.ecommerce_dbt.mart_repeat_purchase", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "0637e18ad5e5b4f49d0e0036aac9df24b75605bf55e4a5be3245494347192dec", "node_finished_at": "", "node_name": "mart_repeat_purchase", "node_path": "marts\\mart_repeat_purchase.sql", "node_relation": {"alias": "mart_repeat_purchase", "database": "ecommerce_pipeline", "relation_name": "ecommerce_pipeline.dev_marts.mart_repeat_purchase", "schema": "dev_marts"}, "node_started_at": "2026-06-07T19:32:07.389171", "node_status": "executing", "resource_type": "model", "unique_id": "model.ecommerce_dbt.mart_repeat_purchase"}, "sql": "create or replace transient table ecommerce_pipeline.dev_marts.mart_repeat_purchase\n    \n    \n    \n    as (with user_carts as (\n    select *\n    from ecommerce_pipeline.dev_intermediate.int_user_carts\n),\n\npurchase_counts as (\n    select\n        user_id,\n        first_name,\n        last_name,\n        age,\n        gender,\n        city,\n        currency,\n        count(cart_id)        as number_of_orders,\n        sum(cart_total)       as total_spent,\n        case\n            when count(cart_id) > 1 then 'Repeat Customer'\n            else 'One Time Customer'\n        end                   as customer_type\n    from user_carts\n    group by\n        user_id,\n        first_name,\n        last_name,\n        age,\n        gender,\n        city,\n        currency\n)\n\nselect * from purchase_counts\norder by number_of_orders desc\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.mart_repeat_purchase\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "8f591da5-dc9e-4945-bd80-f56d314d7758", "level": "debug", "msg": "On model.ecommerce_dbt.mart_repeat_purchase: create or replace transient table ecommerce_pipeline.dev_marts.mart_repeat_purchase\n    \n    \n    \n    as (with user_carts as (\n    select *\n    from ecommerce_pipeline.dev_intermediate.int_user_carts\n),\n\npurchase_counts as (\n    select\n        user_id,\n        first_name,\n        last_name,\n        age,\n        gender,\n        city,\n        currency,\n        count(cart_id)        as number_of_orders,\n        sum(cart_total)       as total_spent,\n        case\n            when count(cart_id) > 1 then 'Repeat Customer'\n            else 'One Time Customer'\n        end                   as customer_type\n    from user_carts\n    group by\n        user_id,\n        first_name,\n        last_name,\n        age,\n        gender,\n        city,\n        currency\n)\n\nselect * from purchase_counts\norder by number_of_orders desc\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.mart_repeat_purchase\"} */;", "name": "SQLQuery", "pid": 10232, "thread": "Thread-1", "ts": "2026-06-07T19:32:07.521558Z"}}
