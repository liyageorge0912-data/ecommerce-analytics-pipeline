{"data": {"conn_name": "model.ecommerce_dbt.int_user_carts", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "7d39e96fba82f9064a0421d3032fdf4a968ebebccf084a1cc795abafe6e0414b", "node_finished_at": "", "node_name": "int_user_carts", "node_path": "intermediate\\int_user_carts.sql", "node_relation": {"alias": "int_user_carts", "database": "ecommerce_pipeline", "relation_name": "ecommerce_pipeline.dev_intermediate.int_user_carts", "schema": "dev_intermediate"}, "node_started_at": "2026-06-07T19:32:06.349133", "node_status": "executing", "resource_type": "model", "unique_id": "model.ecommerce_dbt.int_user_carts"}, "sql": "create or replace   view ecommerce_pipeline.dev_intermediate.int_user_carts\n  \n  \n  \n  \n  as (\n    with users as (\n    select *\n    from ecommerce_pipeline.dev_staging.stg_users\n),\n\ncarts as (\n    select *\n    from ecommerce_pipeline.dev_staging.stg_carts\n),\n\njoined as (\n    select\n        u.user_id,\n        u.first_name,\n        u.last_name,\n        u.age,\n        u.gender,\n        u.city,\n        u.state,\n        u.currency,\n        u.department,\n        u.job_title,\n        u.role,\n        c.cart_id,\n        c.cart_total,\n        c.discounted_total,\n        c.total_products,\n        c.total_quantity\n    from users u\n    left join carts c\n        on u.user_id = c.user_id\n)\n\nselect * from joined\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.int_user_carts\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "8f591da5-dc9e-4945-bd80-f56d314d7758", "level": "debug", "msg": "On model.ecommerce_dbt.int_user_carts: create or replace   view ecommerce_pipeline.dev_intermediate.int_user_carts\n  \n  \n  \n  \n  as (\n    with users as (\n    select *\n    from ecommerce_pipeline.dev_staging.stg_users\n),\n\ncarts as (\n    select *\n    from ecommerce_pipeline.dev_staging.stg_carts\n),\n\njoined as (\n    select\n        u.user_id,\n        u.first_name,\n        u.last_name,\n        u.age,\n        u.gender,\n        u.city,\n        u.state,\n        u.currency,\n        u.department,\n        u.job_title,\n        u.role,\n        c.cart_id,\n        c.cart_total,\n        c.discounted_total,\n        c.total_products,\n        c.total_quantity\n    from users u\n    left join carts c\n        on u.user_id = c.user_id\n)\n\nselect * from joined\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.int_user_carts\"} */;", "name": "SQLQuery", "pid": 10232, "thread": "Thread-4", "ts": "2026-06-07T19:32:06.393176Z"}}
