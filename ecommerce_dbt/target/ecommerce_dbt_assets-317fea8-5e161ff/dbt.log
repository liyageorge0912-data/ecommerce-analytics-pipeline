{"data": {"conn_name": "model.ecommerce_dbt.stg_products", "node_info": {"materialized": "view", "meta": {}, "node_checksum": "390595f239565f26689af4b1b5fb2e6d53ec246b4c7d294c4373b8fb341206fe", "node_finished_at": "", "node_name": "stg_products", "node_path": "staging\\stg_products.sql", "node_relation": {"alias": "stg_products", "database": "ecommerce_pipeline", "relation_name": "ecommerce_pipeline.dev_staging.stg_products", "schema": "dev_staging"}, "node_started_at": "2026-06-07T19:32:04.541962", "node_status": "executing", "resource_type": "model", "unique_id": "model.ecommerce_dbt.stg_products"}, "sql": "create or replace   view ecommerce_pipeline.dev_staging.stg_products\n  \n  \n  \n  \n  as (\n    with source as (\n    select raw_data\n    from ecommerce_pipeline.raw.raw_products\n),\n\nflattened as (\n    select\n        f.value:id::NUMBER                  as product_id,\n        f.value:title::STRING               as product_name,\n        f.value:category::STRING            as category,\n        f.value:brand::STRING               as brand,\n        f.value:price::FLOAT                as price,\n        f.value:discountPercentage::FLOAT   as discount_percentage,\n        f.value:rating::FLOAT               as rating,\n        f.value:stock::NUMBER               as stock,\n        f.value:availabilityStatus::STRING  as availability_status,\n        f.value:returnPolicy::STRING        as return_policy,\n        f.value:shippingInformation::STRING as shipping_information\n    from source s,\n    lateral flatten(input => s.raw_data) f\n)\n\nselect * from flattened\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.stg_products\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "8f591da5-dc9e-4945-bd80-f56d314d7758", "level": "debug", "msg": "On model.ecommerce_dbt.stg_products: create or replace   view ecommerce_pipeline.dev_staging.stg_products\n  \n  \n  \n  \n  as (\n    with source as (\n    select raw_data\n    from ecommerce_pipeline.raw.raw_products\n),\n\nflattened as (\n    select\n        f.value:id::NUMBER                  as product_id,\n        f.value:title::STRING               as product_name,\n        f.value:category::STRING            as category,\n        f.value:brand::STRING               as brand,\n        f.value:price::FLOAT                as price,\n        f.value:discountPercentage::FLOAT   as discount_percentage,\n        f.value:rating::FLOAT               as rating,\n        f.value:stock::NUMBER               as stock,\n        f.value:availabilityStatus::STRING  as availability_status,\n        f.value:returnPolicy::STRING        as return_policy,\n        f.value:shippingInformation::STRING as shipping_information\n    from source s,\n    lateral flatten(input => s.raw_data) f\n)\n\nselect * from flattened\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.stg_products\"} */;", "name": "SQLQuery", "pid": 10232, "thread": "Thread-2", "ts": "2026-06-07T19:32:04.708712Z"}}
