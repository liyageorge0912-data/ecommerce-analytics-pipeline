{"data": {"conn_name": "model.ecommerce_dbt.mart_customer_ltv", "conn_type": "snowflake", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "71281fc414a6b0296f0b0c8cc49573279e082a2b3fe06d524e87f381f4739ac9", "node_finished_at": "", "node_name": "mart_customer_ltv", "node_path": "marts\\mart_customer_ltv.sql", "node_relation": {"alias": "mart_customer_ltv", "database": "ecommerce_pipeline", "relation_name": "ecommerce_pipeline.dev_marts.mart_customer_ltv", "schema": "dev_marts"}, "node_started_at": "2026-06-07T19:32:07.388168", "node_status": "executing", "resource_type": "model", "unique_id": "model.ecommerce_dbt.mart_customer_ltv"}}, "info": {"category": "", "code": "E015", "extra": {}, "invocation_id": "8f591da5-dc9e-4945-bd80-f56d314d7758", "level": "debug", "msg": "Using snowflake connection \"model.ecommerce_dbt.mart_customer_ltv\"", "name": "ConnectionUsed", "pid": 10232, "thread": "Thread-3", "ts": "2026-06-07T19:32:07.513104Z"}}
{"data": {"conn_name": "model.ecommerce_dbt.mart_basket_analysis", "node_info": {"materialized": "table", "meta": {}, "node_checksum": "113a9ebc9332d1dfc2c638531160e01094619171a2b13cbd0a8f145095c8cc35", "node_finished_at": "", "node_name": "mart_basket_analysis", "node_path": "marts\\mart_basket_analysis.sql", "node_relation": {"alias": "mart_basket_analysis", "database": "ecommerce_pipeline", "relation_name": "ecommerce_pipeline.dev_marts.mart_basket_analysis", "schema": "dev_marts"}, "node_started_at": "2026-06-07T19:32:07.386718", "node_status": "executing", "resource_type": "model", "unique_id": "model.ecommerce_dbt.mart_basket_analysis"}, "sql": "create or replace transient table ecommerce_pipeline.dev_marts.mart_basket_analysis\n    \n    \n    \n    as (with user_carts as (\n    select *\n    from ecommerce_pipeline.dev_intermediate.int_user_carts\n),\n\nbasket_analysis as (\n    select\n        currency,\n        count(distinct cart_id) as number_of_orders,\n        avg(cart_total)         as avg_basket_value,\n        avg(total_quantity)     as avg_items_per_basket,\n        avg(total_products)     as avg_products_per_basket,\n        sum(cart_total)         as total_revenue,\n        min(cart_total)         as min_basket_value,\n        max(cart_total)         as max_basket_value\n    from user_carts\n    group by currency\n)\n\nselect * from basket_analysis\norder by total_revenue desc\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.mart_basket_analysis\"} */;"}, "info": {"category": "", "code": "E016", "extra": {}, "invocation_id": "8f591da5-dc9e-4945-bd80-f56d314d7758", "level": "debug", "msg": "On model.ecommerce_dbt.mart_basket_analysis: create or replace transient table ecommerce_pipeline.dev_marts.mart_basket_analysis\n    \n    \n    \n    as (with user_carts as (\n    select *\n    from ecommerce_pipeline.dev_intermediate.int_user_carts\n),\n\nbasket_analysis as (\n    select\n        currency,\n        count(distinct cart_id) as number_of_orders,\n        avg(cart_total)         as avg_basket_value,\n        avg(total_quantity)     as avg_items_per_basket,\n        avg(total_products)     as avg_products_per_basket,\n        sum(cart_total)         as total_revenue,\n        min(cart_total)         as min_basket_value,\n        max(cart_total)         as max_basket_value\n    from user_carts\n    group by currency\n)\n\nselect * from basket_analysis\norder by total_revenue desc\n    )\n\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.mart_basket_analysis\"} */;", "name": "SQLQuery", "pid": 10232, "thread": "Thread-2", "ts": "2026-06-07T19:32:07.514557Z"}}
