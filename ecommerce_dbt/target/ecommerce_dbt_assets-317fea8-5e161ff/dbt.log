LOAT  as discounted_total,\n        f.value:totalProducts::NUMBER   as total_products,\n        f.value:totalQuantity::NUMBER   as total_quantity\n    from source s,\n    lateral flatten(input => s.raw_data) f\n)\n\nselect * from flattened\n  )\n/* {\"app\": \"dbt\", \"dbt_version\": \"1.10.20\", \"profile_name\": \"ecommerce_dbt\", \"target_name\": \"dev\", \"node_id\": \"model.ecommerce_dbt.stg_carts\"} */;", "name": "SQLQuery", "pid": 10232, "thread": "Thread-1", "ts": "2026-06-07T19:32:04.710789Z"}}
